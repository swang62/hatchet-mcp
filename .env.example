# ── LLM Providers ──
OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
VOYAGE_API_KEY="pa-..."

# ── LangSmith (required for Studio, free tier works) ──
LANGSMITH_API_KEY="lsv2_..."
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT="hatchet-mcp"

# ── Hatchet (self-hosted or cloud) ──
# For self-hosted: docker compose -f docker-compose.hatchet.yml up -d
# Login at http://localhost:8888 (admin@example.com / Admin123!!)
# Create tenant, Settings → API Tokens → Create token, paste below:
HATCHET_CLIENT_TOKEN="<paste_token_here>"
HATCHET_CLIENT_HOST="localhost:8888"
