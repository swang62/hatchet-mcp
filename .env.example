# ── LLM agent backend (REQUIRED) ──
OPENAI_API_KEY="sk-"
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_MODEL="openrouter/free"

# ── Worker ENV variables (REQUIRED) ──
HATCHET_CLIENT_TOKEN="eyJ..."
HATCHET_CLIENT_SERVER_URL="http://localhost:8888"
HATCHET_CLIENT_TLS_STRATEGY="none"
DATABASE_URL="postgresql://hatchet:hatchet@localhost:5432/hatchet?sslmode=disable"

# ── LangSmith (optional for debugging) ──
LANGSMITH_API_KEY="lsv2_..."
LANGSMITH_TRACING="true"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT="hatchet-mcp"

# ── Cron Notifications (optional webhook) ──
NOTIFICATION_URL="https://ntfy.sh/my-k8s-alerts"

# ── Docker (update for custom reverse proxy) ──
SERVER_URL="http://localhost:8888"
LOG_LEVEL=info
